# Claude API — optional, used if USE_DEEPSEEK_CAPTION=false
ANTHROPIC_API_KEY=
CLAUDE_VISION_MODEL=claude-haiku-4-5-20251001

# DeepSeek API — vision (admin bot image analysis) and chat (caption generation)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL_VISION=deepseek-v4-flash
DEEPSEEK_MODEL_CHAT=deepseek-v4-flash
# Set to true to use DeepSeek Chat for captions instead of Claude
USE_DEEPSEEK_CAPTION=false

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET_NAME=temp-images
SUPABASE_BOT_UPLOADS_BUCKET=bot-uploads

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to use the admin bot.
# Send /whoami to the bot once it's running to discover your user_id.
TELEGRAM_ALLOWED_USER_IDS=

# Scheduler
POST_TIMES=07:00,10:00,12:00,15:00,18:00,21:00
RETRY_DELAY_MINUTES=15
VERIFICATION_TIME=23:00
CLEANUP_TIME=03:00

# Pipeline
SEEN_EXPIRY_DAYS=3
QUEUE_RETENTION_DAYS=7
MAX_RETRY_ATTEMPTS=3
MIN_ITEMS_THRESHOLD=3
BOT_IMAGE_ORPHAN_HOURS=24
